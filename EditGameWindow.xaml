<Window x:Class="DiscordQuestCompleter.EditGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Game" Height="250" Width="450" Background="#2b2d31" Foreground="#dbdee1"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="20">
        <TextBlock Text="Edit Game Name:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="NameInput" Margin="0,0,0,15" Padding="8" Background="#1e1f22" Foreground="White" BorderThickness="1" BorderBrush="#1e1f22"/>
        
        <TextBlock Text="Edit EXE Path:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="PathInput" Margin="0,0,0,20" Padding="8" Background="#1e1f22" Foreground="White" BorderThickness="1" BorderBrush="#1e1f22"/>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Width="100" Margin="0,0,10,0" Background="#6c757d" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Save Changes" Width="120" Background="#3ba55c" Click="Save_Click"/>
        </Grid>
    </StackPanel>
</Window>
